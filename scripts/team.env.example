# Uso: en cada terminal nueva, antes de lanzar nada:
#   source scripts/team.env
# Deja lista la variable KAFKA_BROKER, y los scripts de MPI
# (run-by-district.sh / run-round-robin.sh) leen las 3 IPs de aquí.

PERSONA_A_IP=100.x.x.x
PERSONA_B_IP=100.x.x.x
PERSONA_C_IP=100.x.x.x

# Persona A es quien hostea Kafka (ver scripts/start-env.sh)
export KAFKA_BROKER="$PERSONA_A_IP:9092"
